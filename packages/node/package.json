{
  "name": "@causal-js/node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./workers/pc-worker-entry": {
      "types": "./dist/workers/pc-worker-entry.d.ts",
      "import": "./dist/workers/pc-worker-entry.js",
      "require": "./dist/workers/pc-worker-entry.cjs"
    },
    "./workers/pc-worker-runtime": {
      "types": "./dist/workers/pc-worker-runtime.d.ts",
      "import": "./dist/workers/pc-worker-runtime.js",
      "require": "./dist/workers/pc-worker-runtime.cjs"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "@causal-js/core": "workspace:*",
    "@causal-js/discovery": "workspace:*"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
